{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "outDir": "lib",
    "rootDir": "src",
    "declarationDir": "lib"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.test.*",
    "src/**/*.stories.*"
  ],
  "references": [
    { "path": "../../packages/superset-core" },
    { "path": "../../packages/superset-ui-core" }
  ]
}
